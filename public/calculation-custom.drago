{
  "drago": true,
  "name": "Drago Custom Analyzer (your engine)",
  "version": 1,
  "method": "custom",
  "target": "color",
  "code": "const DragoAnalyzer = {\n  getColor(num){ const n=parseInt(num); if(n===0) return ['red','violet']; if(n===5) return ['green','violet']; return n%2===0?['red']:['green']; },\n  parse(apiData){ const list=apiData?.data?.list||[]; return list.map(item=>({ issue:item.issueNumber, number:parseInt(item.number), colors:item.color.split(',').map(c=>c.trim()), primary:item.color.split(',')[0].trim() })); },\n  frequency(results){ const freq={}; results.forEach(r=>{ freq[r.number]=(freq[r.number]||0)+1; }); return freq; },\n  colorDist(results){ const dist={red:0,green:0,violet:0}; results.forEach(r=>{ r.colors.forEach(c=>dist[c]=(dist[c]||0)+1); }); const total=results.length||1; return { red:+((dist.red/total)*100).toFixed(1), green:+((dist.green/total)*100).toFixed(1), violet:+((dist.violet/total)*100).toFixed(1) }; },\n  streak(results){ if(!results.length) return {color:null,count:0}; const first=results[0].primary; let count=1; for(let i=1;i<results.length;i++){ if(results[i].primary===first) count++; else break; } return {color:first,count}; },\n  hotCold(results){ const freq=this.frequency(results); const sorted=Object.entries(freq).sort((a,b)=>b[1]-a[1]); return { hot:sorted.slice(0,3).map(([n,c])=>({number:n,count:c})), cold:sorted.slice(-3).reverse().map(([n,c])=>({number:n,count:c})) }; },\n  detectPattern(results){ const colors=results.slice(0,6).map(r=>r.primary); let alternating=true; for(let i=0;i<colors.length-1;i++){ if(colors[i]===colors[i+1]){ alternating=false; break; } } const streak=this.streak(results); if(streak.count>=3) return 'consecutive'; if(alternating) return 'alternating'; return 'mixed'; },\n  predict(results){ const dist=this.colorDist(results); const streak=this.streak(results); const pattern=this.detectPattern(results); const last=results[0]?.primary; let color='green',confidence=50,reason=''; if(streak.count>=3){ color=last==='red'?'green':'red'; confidence=55+Math.min(streak.count*5,20); reason=`${streak.count}x ${last} streak — reversal likely`; } else if(pattern==='alternating'){ color=last==='red'?'green':'red'; confidence=68; reason='Alternating pattern detected'; } else if(Math.abs(dist.red-dist.green)>20){ color=dist.red<dist.green?'red':'green'; confidence=58; reason=`${color} is underrepresented (${dist[color]}%)`; } else { color=dist.green>=dist.red?'green':'red'; confidence=52; reason=`Mixed pattern — slight ${color} edge`; } return {color,confidence,reason,pattern,streak}; },\n  analyze(apiData){ const results=this.parse(apiData); const dist=this.colorDist(results); const streak=this.streak(results); const hc=this.hotCold(results); const pred=this.predict(results); return {results,dist,streak,hotCold:hc,prediction:pred}; }\n};\n"
}